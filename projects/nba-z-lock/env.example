# Ball Don't Lie API Configuration
# Copy this file to .env and fill in your API key

# For free tier, leave API_KEY empty or use your free tier key
# For GOAT tier, use your GOAT tier API key
BALLDONTLIE_API_KEY=

# API Tier: 'free' or 'goat'
API_TIER=free

# Rate limit per minute (free: 5, GOAT: 600)
RATE_LIMIT_PER_MIN=5

# Flask Configuration (optional)
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

