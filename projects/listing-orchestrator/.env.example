# Demo runs without any keys (mock vision + mock channel adapters).

# Optional — richer vision/copy
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Etsy (do this first; no Shopify required) ---
# 1) Create app: https://www.etsy.com/developers/your-apps
# 2) Set keystring below, add callback http://localhost:8765/callback on the app
# 3) python etsy_oauth.py   (writes access/refresh/shop id)
# 4) python verify_accounts.py --channels etsy
ETSY_API_KEY=
# Required (Etsy Feb 2026+): Your Apps → See API Key Details → Shared Secret
ETSY_SHARED_SECRET=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_SHOP_ID=
# Clothing taxonomy node id (required for correct category on live listings)
ETSY_TAXONOMY_ID=
# Optional: reuse a readiness profile id (auto-created if blank)
# ETSY_READINESS_STATE_ID=
# ETSY_SHIPPING_PROFILE_ID=
# ETSY_ORIGIN_POSTAL_CODE=10001
# Etsy marketplace rules: finished goods by someone_else usually need vintage (20+ yrs),
# supplies, or production partners. Modern streetwear resale often fits eBay better.
# ETSY_WHO_MADE=someone_else
# ETSY_WHEN_MADE=2020_2026
# ETSY_IS_SUPPLY=false
# Set true only when you want new listings go live (default = draft after images)
# ETSY_ACTIVATE_LISTINGS=false

# --- eBay (after Etsy works) ---
# EBAY_ACCESS_TOKEN=
# EBAY_ENVIRONMENT=sandbox

# --- Shopify (skip for now) ---
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ADMIN_TOKEN=

# Notifications
# SELLER_NOTIFY_EMAIL=you@example.com

# --- Inventory ledger / DBMS (Phase 2) ---
# CSV is written automatically to outputs/inventory_ledger.csv
# DATABASE_URL=postgresql://cozy:cozy_dev@localhost:5432/cozy_inventory
